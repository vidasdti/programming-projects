NumMFs=5
MF1='idle':'trapmf',[0 0 10 20]
MF2='low':'trimf',[15 30 45]
MF3='medium':'trimf',[40 55 70]
MF4='high':'trimf',[65 80 90]
MF5='max':'trapmf',[85 95 100 100]

[Output2]
Name='elevator_deflection'
